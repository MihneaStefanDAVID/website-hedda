<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description }}" />
    <title>{{ title }}</title>
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cg fill='none' stroke='%23171717' stroke-width='6'%3E%3Crect x='30' y='8' width='42' height='36'/%3E%3Crect x='12' y='30' width='42' height='62'/%3E%3Crect x='46' y='30' width='24' height='62'/%3E%3Crect x='30' y='62' width='42' height='30'/%3E%3C/g%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-name">hedda oprea</a>
      <a href="/contact/" class="contact-link"{% if contactActive %} aria-current="page"{% endif %}>contact</a>
    </header>

    <main{% if mainClass %} class="{{ mainClass }}"{% endif %}>
      {{ content | safe }}
    </main>

    {% if includeScript %}<script src="/script.js"></script>{% endif %}
  </body>
</html>
