<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description }}" />
    <title>{{ title }}</title>
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='91.92 193.84 411.16 477.32'%3E%3Cg fill='none' stroke='%23171717' stroke-width='24'%3E%3Crect x='238.56' y='193.84' width='206.95' height='169.64'/%3E%3Crect x='390.94' y='291.59' width='112.13' height='304.81'/%3E%3Crect x='238.56' y='541.78' width='206.96' height='129.38'/%3E%3Crect x='91.92' y='291.59' width='201.27' height='304.73'/%3E%3C/g%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-name">hedda oprea</a>
      <a href="/contact/" class="contact-link"{% if contactActive %} aria-current="page"{% endif %}>contact</a>
    </header>

    <main{% if mainClass %} class="{{ mainClass }}"{% endif %}>
      {{ content | safe }}
    </main>

    {% if includeScript %}<script src="/script.js"></script>{% endif %}
  </body>
</html>
